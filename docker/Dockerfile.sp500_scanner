FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Install dependencies first so this layer is cached across code-only changes
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# APScheduler inside scanner.py handles the 21:30 UTC Mon–Fri schedule.
# No cron needed — the process runs continuously and sleeps between market sessions.
CMD ["python", "SP500/scanner/scanner.py"]
