FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Long-polling loop — must stay alive to receive Accept/Reject callbacks.
# docker-compose.yml sets restart: always for this service.
CMD ["python", "52WeekHigh/bot/bot.py"]
