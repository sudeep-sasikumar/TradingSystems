# ─── Telegram Bot ───────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here

# ─── Live Trading Controls ────────────────────────────────────────────────────
# Max concurrent open positions. Signals still fire when cap is reached,
# but message includes [CAP REACHED] warning.
MAX_CONCURRENT_POSITIONS=20

# S&P 500 position cap (defaults to MAX_CONCURRENT_POSITIONS if unset).
SP500_MAX_CONCURRENT_POSITIONS=20

# ─── Dashboard ───────────────────────────────────────────────────────────────
DASHBOARD_PORT=8502

# ─── Paths (defaults work for both Docker and local dev) ──────────────────────
DB_PATH=./data/trading.db
CACHE_DIR=./data/cache

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
